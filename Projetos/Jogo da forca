#include <iostream>
#include <stdlib.h>
using namespace std;
int main(){
	int i, tam, chance, acertos;
	char palavra[30], letra[1], resposta[30];
	bool acerto = false;
	chance = 6;
	i = 0;
	tam = 0;
	acertos = 0;		
	
		cout<<"Insira a palavra que vai ser descoberta: "<<endl;
		cin>>palavra;
		system("cls");
		
			while(palavra[i] != '\0'){
			i++;
			tam++;
						}
						
					for(i=0;i<30;i++){
						resposta[i]='-';
									}
		
			while(chance > 0 && acertos < tam){
				cout<<"Voce tem "<<chance<<" chances"<<endl<<endl;
				cout<<"Palavra secreta: "<<endl;
					for(i=0; i<tam;i++){
						cout<<resposta[i];}
						cout<<endl<<"Digite uma letra: ";
						cin>>letra[0];
							for(i=0;i<tam;i++){
								if(palavra[i]==letra[0]){
									acerto=true;
									resposta[i]=palavra[i];
									acertos++;
	
								}
							}
						if(!acerto){
							chance--;
						}
						
						acerto=false;
						system("cls");
						
	}
	if(acertos==tam){
		cout<<"Voce acertou!"<<endl;
	}
	else{
		cout<<"Voce errou :("<<endl;
	}
	
	
	return 0;
}
