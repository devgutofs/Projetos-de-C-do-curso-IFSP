#include <iostream>
using namespace std;
int main(){
	double n;
	cin>>n;
	if(n<0||n>100){
		cout<<"Fora de intervalo"<<endl;
	}
	else if(25>=n){
		cout<<"Intervalo [0,25]"<<endl;
	}
	else if(50>=n){
		cout<<"Intervalo (25,50]"<<endl;
	}
	else if(75>=n){
		cout<<"Intervalo (50,75]"<<endl;
	}
	else{
		cout<<"Intervalo (75,100]"<<endl;
	}
	
	
	return 0;
}
